# ── Core API Keys ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Pipeline Mode ──────────────────────────────────────────
# "demo"       → uses Gemini API for STT + triage
# "production" → uses IndicConformer + Qwen3 via Ollama
PIPELINE_MODE=demo

# ── Alert Channels (leave blank to disable either) ─────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# ── Audio Capture ──────────────────────────────────────────
SAMPLE_RATE=16000
CHUNK_DURATION_SECONDS=8
SILENCE_THRESHOLD=200
DIARIZATION_ENABLED=false
HUGGINGFACE_TOKEN=   # Required if DIARIZATION_ENABLED=true
# Get token from: https://huggingface.co/settings/tokens
# Accept pyannote terms at: https://huggingface.co/pyannote/speaker-diarization-3.1
MIN_SPEAKER_SEGMENT_SECONDS=1.0

# ── Dashboard Auth (leave PASS blank to disable auth) ──────
DASHBOARD_AUTH_USER=admin
DASHBOARD_AUTH_PASS=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Database ───────────────────────────────────────────────
DB_PATH=sessions.db
# Postgres: set this to enable Postgres mode (production only)
# Format: postgresql://user:password@host:5432/dbname
POSTGRES_URL=

# ── Production: Ollama ─────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ── Production: GPU Device ─────────────────────────────────
DEVICE=cpu
# Set to "cuda" on GPU server

# ── Scheduler ──────────────────────────────────────────────
REPORT_HOUR=21

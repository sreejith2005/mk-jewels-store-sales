# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
TELEGRAM_BOT_TOKEN=   # Active — Telegram restored June 2025
TELEGRAM_CHAT_ID=     # Manager's chat or group chat ID

# Application Configuration Defaults
PIPELINE_MODE=demo
ALERT_THRESHOLD=medium
CHUNK_DURATION_SECONDS=8
SAMPLE_RATE=16000
DEVICE=cuda
DB_PATH=sessions.db
POSTGRES_URL=
# Leave blank for SQLite (demo). Set to Supabase connection string for production.
# Get from: Supabase dashboard -> Settings -> Database -> Connection string -> URI

# Optional for local dev: leave DASHBOARD_AUTH_PASS empty to disable dashboard auth.
DASHBOARD_AUTH_USER=admin
DASHBOARD_AUTH_PASS=
